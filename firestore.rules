rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Restaurants and their sub-collections
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == restaurantId;
      
      // Sub-collections (products, waiters, tables, reviews, printers, etc.)
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == restaurantId;
      }
    }

    // Waiter Index for login
    match /waiter_index/{email} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.restaurantId == request.auth.uid;
      allow update: if request.auth != null && resource.data.restaurantId == request.auth.uid && request.resource.data.restaurantId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.restaurantId == request.auth.uid;
    }
    
    // User orders
    match /orders/{orderId} {
      // Users can read if they are owner, restaurant, assigned driver or if it's finding driver
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.restaurantId ||
        request.auth.uid == resource.data.deliveryDriverId ||
        resource.data.status == 'finding_driver'
      );
      // Users can only create orders for themselves
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Restaurants and Drivers can update status
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.restaurantId || 
        request.auth.uid == resource.data.deliveryDriverId ||
        exists(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)/waiters/$(request.auth.uid)) ||
        // Allow self-assignment
        (resource.data.status == 'finding_driver' && request.resource.data.status == 'driver_assigned')
      );
      allow delete: if false;
    }

    // Delivery Drivers profiles
    match /delivery_drivers/{driverId} {
      allow read, write: if request.auth != null && request.auth.uid == driverId;
    }

    // Wallet recharges
    match /wallet_recharges/{rechargeId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // System configurations (for payment methods)
    match /system_configs/finances {
      allow read: if true;
    }

    // Transport requests (Taxi)
    match /transport_requests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.driverId || 
        request.auth.token.admin == true ||
        resource.data.status == 'searching'
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.driverId ||
        (resource.data.status == 'searching' && request.resource.data.status == 'accepted')
      );
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == request.resource.data.restaurantId || 
        request.auth.uid == resource.data.restaurantId
      );
    }

    // Banner Updates (for stats)
    match /banner_updates/{updateId} {
      allow read, create: if request.auth != null && (
        request.auth.uid == request.resource.data.restaurantId || 
        request.auth.uid == resource.data.restaurantId
      );
    }

    // Delivery and Transport settings
    match /delivery_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}