rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function for Cpanel Admin
    function isCPanelAdmin() {
      return request.auth != null && 
             request.auth.token.email.lower() == 'louismarketing@2x3consigueloquequieras.com';
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isCPanelAdmin());
    }
    
    // Restaurants and their sub-collections
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      
      // Sub-collections (products, waiters, tables, reviews, printers, etc.)
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      }
    }

    // Waiter Index for login
    match /waiter_index/{email} {
      allow read: if true;
      allow create: if (request.auth != null && request.resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
      allow update: if (request.auth != null && resource.data.restaurantId == request.auth.uid && request.resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
      allow delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
    }
    
    // User orders
    match /orders/{orderId} {
      // Users can read if they are owner, restaurant, assigned driver or if it's finding driver
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.restaurantId ||
        request.auth.uid == resource.data.deliveryDriverId ||
        resource.data.status == 'finding_driver' ||
        isCPanelAdmin()
      );
      // Users can only create orders for themselves
      allow create: if (request.auth != null && request.auth.uid == request.resource.data.userId) || isCPanelAdmin();
      // Restaurants and Drivers can update status
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.restaurantId || 
        request.auth.uid == resource.data.deliveryDriverId ||
        exists(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)/waiters/$(request.auth.uid)) ||
        // Allow self-assignment
        (resource.data.status == 'finding_driver' && request.resource.data.status == 'driver_assigned') ||
        isCPanelAdmin()
      );
      allow delete: if isCPanelAdmin();
    }

    // Delivery Drivers profiles
    match /delivery_drivers/{driverId} {
      allow read, write: if (request.auth != null && request.auth.uid == driverId) || isCPanelAdmin();
    }

    // Wallet recharges
    match /wallet_recharges/{rechargeId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.admin == true || isCPanelAdmin());
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.userId || isCPanelAdmin());
    }

    // System configurations
    match /system_configs/{configId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }

    // Transport requests (Taxi)
    match /transport_requests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.driverId || 
        request.auth.token.admin == true ||
        resource.data.status == 'searching' ||
        isCPanelAdmin()
      );
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.userId || isCPanelAdmin());
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.driverId ||
        (resource.data.status == 'searching' && request.resource.data.status == 'accepted') ||
        isCPanelAdmin()
      );
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isCPanelAdmin());
      allow create: if request.auth != null;
    }

    // Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == request.resource.data.restaurantId || 
        request.auth.uid == resource.data.restaurantId ||
        isCPanelAdmin()
      );
    }

    // Banner Updates (for stats)
    match /banner_updates/{updateId} {
      allow read, create: if request.auth != null && (
        request.auth.uid == request.resource.data.restaurantId || 
        request.auth.uid == resource.data.restaurantId ||
        isCPanelAdmin()
      );
    }

    // Delivery and Transport settings
    match /delivery_settings/{docId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }

    // Delivery update requests
    match /delivery_update_requests/{requestId} {
      allow read, write: if isCPanelAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}