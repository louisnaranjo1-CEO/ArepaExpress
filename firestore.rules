rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Public Data
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == restaurantId;
      
      match /products/{productId} {
      	allow read: if true;
        allow write: if request.auth != null && request.auth.uid == restaurantId;
      }
    }
    
    // User orders
    match /orders/{orderId} {
      // Users can read if they are the owner or the restaurant
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.restaurantId);
      // Users can only create orders for themselves
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Restaurants can update status
      allow update: if request.auth != null && request.auth.uid == resource.data.restaurantId;
      allow delete: if false;
    }

    // Wallet recharges
    match /wallet_recharges/{rechargeId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // System configurations (for payment methods)
    match /system_configs/finances {
      allow read: if true;
    }

    // Transport requests (Taxi)
    match /transport_requests/{requestId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.driverId || request.auth.token.admin == true);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null; // Allow drivers to accept and update
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}