rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function for Cpanel Admin
    function isCPanelAdmin() {
      return request.auth != null && (
        (request.auth.token.keys().hasAll(['email']) && request.auth.token.email != null && (
          request.auth.token.email.lower() == 'louismarketing@2x3consigueloquequieras.com' ||
          request.auth.token.email.lower() == 'louisnaranjo1@gmail.com'
        )) ||
        (request.auth.token.keys().hasAll(['admin']) && request.auth.token.admin == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // User profiles (LOCKED DOWN: Only authenticated reads)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isCPanelAdmin() || 
        // User updating their own profile (cannot change points/referrals)
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'totalReferrals'])) ||
        // Another user (e.g., restaurant admin or referred user) updating ONLY points and referrals
        (request.auth.uid != userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'totalReferrals']))
      );
      allow delete: if request.auth != null && (request.auth.uid == userId || isCPanelAdmin());
    }
    // Staff sessions validation
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == sessionId;
    }

    // Waiter and Cashier Indexes
    match /waiter_index/{email} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /cashier_index/{email} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Restaurants and their public data
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      
      // Sub-collections: Only specific public things shouldn't be locked
      match /products/{modId} { allow read: if true; allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin(); }
      match /categories/{modId} { allow read: if true; allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin(); }
      match /reviews/{modId} { 
        allow read: if true; 
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin(); 
      }
      match /followers/{followerId} {
        allow read, write: if (request.auth != null && request.auth.uid == followerId) || isCPanelAdmin();
      }

      // Waiters, Cashiers, Printers, and Tables access for staff
      match /tables/{tableId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == restaurantId || 
          isCPanelAdmin() ||
          (exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) && get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.restaurantId == restaurantId)
        );
      }
      match /printers/{printerId} {
        allow read: if request.auth != null;
        allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      }
      match /waiters/{waiterId} {
        allow read: if request.auth != null;
        allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      }
      match /cashiers/{cashierId} {
        allow read: if request.auth != null;
        allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      }

      // Other Private Data inside restaurants
      match /{privateData=**} {
        allow read, write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      }
    }

    // Waiter & Cashier Index
    match /waiter_index/{email} {
      allow read: if true;
      allow create: if (request.auth != null && request.resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
      allow update, delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
    }
    match /cashier_index/{email} {
      allow read: if true;
      allow create: if (request.auth != null && request.resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
      allow update, delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
    }
    
    // User orders (LOCKED DOWN: Split Get and List)
    match /orders/{orderId} {
      // 1. GET (Read 1 specific order) -> Guests can see their order if they know the exact link ID
      allow get: if true; 

      // 2. LIST (List multiple orders) -> Locked out from public scraping
      allow list: if request.auth != null && (
        request.auth.uid == resource.data.restaurantId || 
        request.auth.uid == resource.data.deliveryDriverId ||
        request.auth.uid == resource.data.userId || 
        (exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) && get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.restaurantId == resource.data.restaurantId) ||
        isCPanelAdmin()
      );
      
      // Allow guests and waiters (no auth required right now) to create orders
      allow create: if true;
      
      // Restrictions to update status/payments
      allow update: if (request.auth != null && (
        request.auth.uid == resource.data.restaurantId || 
        request.auth.uid == resource.data.deliveryDriverId ||
        (exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) && get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.restaurantId == resource.data.restaurantId) ||
        (resource.data.status == 'finding_driver' && request.resource.data.status == 'driver_assigned')
      )) || 
      // Permit guests to attach payment
      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['restaurantId', 'userId', 'items'])) ||
      isCPanelAdmin();
      
      allow delete: if isCPanelAdmin();

      // Chat Messages
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Delivery Drivers profiles — lectura pública para disponibilidad en Taxi
    match /delivery_drivers/{driverId} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && request.auth.uid == driverId) || isCPanelAdmin();
    }

    // Wallet recharges
    match /wallet_recharges/{rechargeId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.admin == true || isCPanelAdmin());
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.userId || isCPanelAdmin());
    }

    // Transport requests (Taxi) (LOCKED DOWN: Split Get and List)
    match /transport_requests/{requestId} {
      // Allow guests to see their own exact taxi matching ID
      allow get: if true;
      
      // Do not allow people to download all taxi history globally!
      allow list: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.driverId || 
        request.auth.token.admin == true ||
        resource.data.status == 'searching' || // Pilots looking for jobs
        isCPanelAdmin()
      );

      allow create: if (request.auth != null && (request.auth.uid == request.resource.data.userId || isCPanelAdmin())) || request.resource.data.userId.matches('guest_.*');
      
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.driverId ||
        (resource.data.status == 'searching' && request.resource.data.status == 'accepted') ||
        isCPanelAdmin()
      );
      allow delete: if isCPanelAdmin();

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Default general rules...
    match /notifications/{notifId} { allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isCPanelAdmin()); allow create: if request.auth != null; }
    match /banners/{bannerId} { allow read: if true; allow write: if request.auth != null && ( request.auth.uid == request.resource.data.restaurantId || request.auth.uid == resource.data.restaurantId || isCPanelAdmin()); }
    match /banner_updates/{updateId} { allow read, create: if request.auth != null && ( request.auth.uid == request.resource.data.restaurantId || request.auth.uid == resource.data.restaurantId || isCPanelAdmin()); }
    match /delivery_settings/{docId} { allow read: if true; allow write: if isCPanelAdmin(); }
    match /system_configs/{configId} { allow read: if true; allow write: if isCPanelAdmin(); }
    match /system_settings/{docId} { allow read: if true; allow write: if isCPanelAdmin(); }
    
    // CPanel Managed Public
    match /global_categories/{categoryId} { allow read: if true; allow write: if isCPanelAdmin(); }
    match /raffles/{raffleId} { allow read: if true; allow write: if isCPanelAdmin(); }
    match /referral_contests/{contestId} { allow read: if true; allow write: if isCPanelAdmin(); }
    match /home_icons/{iconId} { allow read: if true; allow write: if isCPanelAdmin(); }
    match /global_icons/{iconId} { allow read: if true; allow write: if isCPanelAdmin(); }
    match /payment_methods/{methodId} { allow read: if true; allow write: if isCPanelAdmin(); }
    match /push_campaigns/{campaignId} { allow read: if true; allow create: if request.auth != null; allow update, delete: if isCPanelAdmin() || (request.auth != null && resource.data.restaurantId == request.auth.uid); }

    // Subscriptions & Wallets
    match /subscriptions/{subId} { allow read: if true; allow write: if isCPanelAdmin() || (request.auth != null && request.auth.uid == request.resource.data.restaurantId); }
    match /wallets/{walletId} { allow read: if request.auth != null && (request.auth.uid == walletId || isCPanelAdmin()); allow write: if isCPanelAdmin(); }
    match /support_tickets/{ticketId} { allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isCPanelAdmin()); allow create: if request.auth != null && request.auth.uid == request.resource.data.userId; allow update, delete: if isCPanelAdmin(); }
    match /delivery_update_requests/{requestId} { allow read: if isCPanelAdmin() || (request.auth != null && resource.data.driverId == request.auth.uid); allow create: if request.auth != null && request.resource.data.driverId == request.auth.uid; allow update, delete: if isCPanelAdmin(); }

    // Lost items — user creates, driver reads their own, admin manages
    match /lost_items/{itemId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isCPanelAdmin()
      );
      allow update, delete: if isCPanelAdmin();
    }

    match /{document=**} { allow read, write: if false; }
  }
}