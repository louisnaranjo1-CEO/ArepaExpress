rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function for Cpanel Admin
    function isCPanelAdmin() {
      return request.auth != null && (
        (request.auth.token.keys().hasAll(['email']) && request.auth.token.email != null && (
          request.auth.token.email.lower() == 'louismarketing@2x3consigueloquequieras.com' ||
          request.auth.token.email.lower() == 'louisnaranjo1@gmail.com'
        )) ||
        (request.auth.token.keys().hasAll(['admin']) && request.auth.token.admin == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // User profiles
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isCPanelAdmin() || 
        // User updating their own profile (cannot change points/referrals)
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'totalReferrals'])) ||
        // Another user (e.g., restaurant admin or referred user) updating ONLY points and referrals
        (request.auth.uid != userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'totalReferrals']))
      );
      allow delete: if request.auth != null && (request.auth.uid == userId || isCPanelAdmin());
    }
    
    // Restaurants and their sub-collections
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      
      // Sub-collections (products, waiters, tables, reviews, printers, etc.)
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if (request.auth != null && request.auth.uid == restaurantId) || isCPanelAdmin();
      }
    }

    // Waiter Index for login
    match /waiter_index/{email} {
      allow read: if true;
      allow create: if (request.auth != null && request.resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
      allow update: if (request.auth != null && resource.data.restaurantId == request.auth.uid && request.resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
      allow delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
    }

    // Cashier Index for login
    match /cashier_index/{email} {
      allow read: if true;
      allow create: if (request.auth != null && request.resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
      allow update: if (request.auth != null && resource.data.restaurantId == request.auth.uid && request.resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
      allow delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isCPanelAdmin();
    }
    
    // User orders
    match /orders/{orderId} {
      allow read: if true; // Allow guests, waiters, and cashiers to read orders
      // Allow guests and waiters (no auth) to create orders
      allow create: if true;
      // Restaurants and Drivers can update status, plus cashiers (unauthenticated) for payment
      allow update: if (request.auth != null && (
        request.auth.uid == resource.data.restaurantId || 
        request.auth.uid == resource.data.deliveryDriverId ||
        exists(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)/waiters/$(request.auth.uid)) ||
        // Allow self-assignment
        (resource.data.status == 'finding_driver' && request.resource.data.status == 'driver_assigned')
      )) || 
      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['restaurantId', 'userId', 'items'])) ||
      isCPanelAdmin();
      allow delete: if isCPanelAdmin();
    }

    // Delivery Drivers profiles
    match /delivery_drivers/{driverId} {
      allow read, write: if (request.auth != null && request.auth.uid == driverId) || isCPanelAdmin();
    }

    // Wallet recharges
    match /wallet_recharges/{rechargeId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.admin == true || isCPanelAdmin());
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.userId || isCPanelAdmin());
    }

    // System configurations
    match /system_configs/{configId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }

    // Transport requests (Taxi)
    match /transport_requests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.driverId || 
        request.auth.token.admin == true ||
        resource.data.status == 'searching' ||
        isCPanelAdmin()
      );
      allow create: if (request.auth != null && (request.auth.uid == request.resource.data.userId || isCPanelAdmin())) || request.resource.data.userId.matches('guest_.*');
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.driverId ||
        (resource.data.status == 'searching' && request.resource.data.status == 'accepted') ||
        isCPanelAdmin()
      );
      allow delete: if isCPanelAdmin();

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isCPanelAdmin());
      allow create: if request.auth != null;
    }

    // Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == request.resource.data.restaurantId || 
        request.auth.uid == resource.data.restaurantId ||
        isCPanelAdmin()
      );
    }

    // Banner Updates (for stats)
    match /banner_updates/{updateId} {
      allow read, create: if request.auth != null && (
        request.auth.uid == request.resource.data.restaurantId || 
        request.auth.uid == resource.data.restaurantId ||
        isCPanelAdmin()
      );
    }

    // Delivery and Transport settings
    match /delivery_settings/{docId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }

    // Delivery update requests
    match /delivery_update_requests/{requestId} {
      allow read: if isCPanelAdmin() || (request.auth != null && resource.data.driverId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.driverId == request.auth.uid;
      allow update, delete: if isCPanelAdmin();
    }

    // CPanel Managed Collections
    match /global_categories/{categoryId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }
    
    match /raffles/{raffleId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }
    
    match /referral_contests/{contestId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }
    
    match /home_icons/{iconId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }

    match /global_icons/{iconId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }
    
    match /payment_methods/{methodId} {
      allow read: if true;
      allow write: if isCPanelAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if true;
      allow write: if isCPanelAdmin() || (request.auth != null && request.auth.uid == request.resource.data.restaurantId);
    }

    match /wallets/{walletId} {
      allow read: if request.auth != null && (request.auth.uid == walletId || isCPanelAdmin());
      allow write: if isCPanelAdmin();
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isCPanelAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if isCPanelAdmin();
      allow delete: if isCPanelAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}