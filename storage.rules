rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function for Cpanel Admin
    function isCPanelAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'louismarketing@2x3consigueloquequieras.com' ||
        request.auth.token.email.lower() == 'louisnaranjo1@gmail.com' ||
        request.auth.token.admin == true ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Admin can read and write everything
    match /{allPaths=**} {
      allow read, write: if isCPanelAdmin();
    }

    // Publicly readable folders
    match /restaurants/{allPaths=**} { allow read: if true; }
    match /banners/{allPaths=**} { allow read: if true; }
    match /global_icons/{allPaths=**} { allow read: if true; }
    match /payment_logos/{allPaths=**} { allow read: if true; }
    match /waiters/{allPaths=**} { allow read: if true; }
    match /users/{allPaths=**} { allow read: if true; }

    // Root files (like the Cashea logo 'unnamed (14).jpg')
    match /{fileName} {
      allow read: if true;
    }

    // Restricted folders - Admin or Owner
    match /delivery_docs/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isCPanelAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /taxi_proofs/{userId}/{allPaths=**} {
      allow read: if isCPanelAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if true; // Permitimos a todos, incluyendo invitados ('guest_...'), subir recibos de taxi
    }

    match /wallet_recharges/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isCPanelAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Fallback for specific restaurant assets
    match /restaurants/{restaurantId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == restaurantId;
    }

    match /push_campaigns/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
