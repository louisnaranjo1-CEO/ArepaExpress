rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function for Cpanel Admin
    function isCPanelAdmin() {
      return request.auth != null && 
             request.auth.token.email.lower() == 'louismarketing@2x3consigueloquequieras.com';
    }

    // Admin can read and write everything
    match /{allPaths=**} {
      allow read, write: if isCPanelAdmin();
    }

    match /restaurants/{restaurantId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == restaurantId;
    }

    match /delivery_docs/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /global_icons/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /taxi_proofs/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /payment_logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /wallet_recharges/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /waiters/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

