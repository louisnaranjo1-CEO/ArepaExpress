{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "arepaexpress",
    "pages_build_output_dir": "dist",
    "assets": {
        "directory": "./dist",
        "not_found_handling": "single-page-application"
    },
    "compatibility_date": "2024-11-01",
    "observability": {
        "enabled": true
    }
}